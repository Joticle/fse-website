@page
@model FlowState.Pages.LegacyModel
@{
    ViewData["Title"] = "Legacy Manifesto";
}

<section class="fse-page-hero">
    <div class="fse-container-narrow">
        <span class="fse-badge">Archive &middot; October 2025</span>
        <h1>The Original Manifesto</h1>
        <p>
            This is the original FlowState Engineering manifesto, written in October 2025 in the
            first hours of realization. Every tenet below became a concrete engineering practice.
        </p>
    </div>
</section>

<section class="fse-hero">
    <div class="fse-hero-inner">
        <span class="fse-hero-badge">
            <span aria-hidden="true">&#9670;</span>
            <span>The Cognitive Development Paradigm</span>
        </span>
        <h1 class="fse-hero-title">
            <span class="fse-gradient-text">Flowstate</span> Engineering&trade;
        </h1>
        <p class="fse-hero-subtitle">
            Where human intuition and machine intelligence move as one.
            A living paradigm where planning and execution converge.
        </p>
        <div class="fse-hero-actions">
            <span class="fse-badge fse-badge-dark">Context Is The Code.</span>
        </div>
        <p class="fse-hero-meta">Created by Scott Michael Wilson &mdash; October 2025</p>
    </div>
</section>

<section class="fse-section">
    <div class="fse-container">
        <div class="fse-section-header">
            <span class="fse-eyebrow">Overview</span>
            <h2>Three Movements</h2>
        </div>
        <div class="fse-card-grid">
            <article class="fse-card">
                <div class="fse-card-icon">&#9670;</div>
                <h3>Living Paradigm</h3>
                <p>Constant loop of creation, reflection, and evolution.</p>
            </article>
            <article class="fse-card">
                <div class="fse-card-icon">&#9670;</div>
                <h3>Adaptive Code</h3>
                <p>Context is command. Code is not static &mdash; it's alive.</p>
            </article>
            <article class="fse-card">
                <div class="fse-card-icon">&#9670;</div>
                <h3>Continuous Flow</h3>
                <p>Every commit refines the organism.</p>
            </article>
        </div>
    </div>
</section>

<section class="fse-section">
    <div class="fse-container-narrow">
        <blockquote class="fse-quote">
            We don't plan and then build &mdash; <strong>we build as we plan.</strong><br />
            We don't react to change &mdash; <strong>we flow with it.</strong>
        </blockquote>
    </div>
</section>

<section class="fse-section">
    <div class="fse-container">
        <div class="fse-section-header">
            <span class="fse-eyebrow">Foundation</span>
            <h2>The Ten Tenets</h2>
            <p>As originally written in October 2025.</p>
        </div>
        <div class="fse-tenet-grid">
            <article class="fse-tenet">
                <span class="fse-tenet-num">01</span>
                <h3>Thought and Action Are One</h3>
                <p>Design, plan, and execution are inseparable.</p>
            </article>
            <article class="fse-tenet">
                <span class="fse-tenet-num">02</span>
                <h3>Intelligence Is Symbiotic</h3>
                <p>AI is a collaborator. Human and machine co-create.</p>
            </article>
            <article class="fse-tenet">
                <span class="fse-tenet-num">03</span>
                <h3>The Plan Lives</h3>
                <p>Architecture and intent evolve continuously.</p>
            </article>
            <article class="fse-tenet">
                <span class="fse-tenet-num">04</span>
                <h3>Evolution Replaces Iteration</h3>
                <p>Each commit refines the organism.</p>
            </article>
            <article class="fse-tenet">
                <span class="fse-tenet-num">05</span>
                <h3>Flow Over Friction</h3>
                <p>Uninterrupted cognitive flow drives productivity.</p>
            </article>
            <article class="fse-tenet">
                <span class="fse-tenet-num">06</span>
                <h3>Context Is The Code</h3>
                <p>The why lives beside the what &mdash; context executes logic.</p>
            </article>
            <article class="fse-tenet">
                <span class="fse-tenet-num">07</span>
                <h3>Adaptation Is The Default</h3>
                <p>Change is the constant pulse of progress.</p>
            </article>
            <article class="fse-tenet">
                <span class="fse-tenet-num">08</span>
                <h3>Transparency Is Trust</h3>
                <p>Every decision is traceable and accountable.</p>
            </article>
            <article class="fse-tenet">
                <span class="fse-tenet-num">09</span>
                <h3>Knowledge Is a Living Network</h3>
                <p>Every interaction strengthens shared intelligence.</p>
            </article>
            <article class="fse-tenet">
                <span class="fse-tenet-num">10</span>
                <h3>Creation Is Continuous</h3>
                <p>Systems live, learn, and evolve perpetually.</p>
            </article>
        </div>
    </div>
</section>

<section class="fse-section fse-section-dark">
    <div class="fse-container-narrow">
        <div class="fse-section-header">
            <span class="fse-eyebrow">Our Promise</span>
            <h2>The Creed</h2>
        </div>
        <p class="fse-creed-text fse-note-center-dark">
            We are not maintainers of process &mdash; we are movers of flow.<br />
            We cultivate systems that think, adapt, and evolve with us.<br />
            We don't manage change &mdash; we <strong>become</strong> it.<br />
            We don't code in isolation &mdash; we code in <strong>context</strong>.
        </p>
        <p class="fse-cta-center">
            <span class="fse-badge fse-badge-dark">We are Flowstate Engineers.</span>
        </p>
    </div>
</section>

<section class="fse-section">
    <div class="fse-container-narrow">
        <p class="fse-cta-center">
            <a class="fse-btn fse-btn-primary" asp-page="/Index">&larr; Back to the Live Methodology</a>
        </p>
    </div>
</section>
